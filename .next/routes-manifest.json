{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "ontimer.app"
        }
      ],
      "destination": "https://www.ontimer.app/:path*",
      "statusCode": 308,
      "regex": "^(?!/_next)(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
    },
    {
      "source": "/privacy",
      "destination": "https://ontimer.app/OnTimer_Privacy_Policy.html",
      "statusCode": 308,
      "regex": "^(?!/_next)/privacy(?:/)?$"
    },
    {
      "source": "/terms",
      "destination": "https://ontimer.app/OnTimer_Terms_of_Service.html",
      "statusCode": 308,
      "regex": "^(?!/_next)/terms(?:/)?$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/blog/[slug]",
      "regex": "^/blog/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/blog/(?<nxtPslug>[^/]+?)(?:/)?$"
    }
  ],
