10:["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"WebPage\",\"name\":\"Never Miss a Zoom Meeting Again\",\"description\":\"How persistent meeting alarms help remote workers avoid missing Zoom calls and Teams meetings.\",\"url\":\"https://www.ontimer.app/zoom-meeting-reminder\"}"}}],["$","section",null,{"className":"relative overflow-hidden pb-20 pt-24 md:pt-32","children":[["$","div",null,{"className":"pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,rgba(34,197,94,0.15),transparent)]"}],["$","div",null,{"className":"mx-auto max-w-3xl px-4 sm:px-6","children":[["$","h1",null,{"className":"text-5xl font-black tracking-tight text-white sm:text-6xl","children":["Never Miss a"," ",["$","span",null,{"className":"text-green-500","children":"Zoom Meeting Again"}]]}],["$","p",null,{"className":"mt-6 text-lg text-zinc-400 leading-relaxed","children":"Zoom and Teams meeting reminders behave like standard calendar notifications — they appear briefly, then disappear. For remote workers who are focused on tasks between calls, these reminders are easy to miss."}],["$","p",null,{"className":"mt-4 text-lg text-zinc-400 leading-relaxed","children":"Persistent meeting alarms fix this. Here's how."}],["$","div",null,{"className":"mt-8 flex flex-wrap items-center gap-4","children":[["$","$L7",null,{"size":"lg"}],["$","$L13",null,{"size":"lg"}]]}]]}]]}],["$","section",null,{"className":"border-t border-zinc-800 bg-zinc-900/50 py-20","children":["$","div",null,{"className":"mx-auto max-w-3xl px-4 sm:px-6","children":[["$","h2",null,{"className":"text-3xl font-black tracking-tight text-white sm:text-4xl","children":"Why Zoom Meeting Reminders Are Easy to Miss"}],["$","div",null,{"className":"mt-6 space-y-4 text-zinc-400 leading-relaxed","children":[["$","p",null,{"children":"Zoom itself sends meeting reminders — but they're delivered through the same notification system as everything else on your phone or computer."}],["$","p",null,{"children":"That means they can be swiped away, buried, silenced by focus mode, or simply missed while you're heads-down on something else."}],["$","p",null,{"children":"Google Calendar and Outlook send their own reminders too — but these face exactly the same problem. A notification banner that appears for a few seconds isn't designed to interrupt deep work."}]]}]]}]}],["$","section",null,{"className":"py-20","children":["$","div",null,{"className":"mx-auto max-w-3xl px-4 sm:px-6","children":[["$","h2",null,{"className":"text-3xl font-black tracking-tight text-white sm:text-4xl","children":"How Remote Workers Lose Track of Meetings"}],["$","p",null,{"className":"mt-4 text-zinc-400","children":"Remote work removes the in-person cues that naturally keep you on schedule. Several factors make meeting timing harder:"}],["$","div",null,{"className":"mt-6 grid gap-4 sm:grid-cols-2","children":[["$","div","No physical cues",{"className":"rounded-2xl border border-zinc-800 bg-zinc-900 p-6","children":[["$","h3",null,{"className":"font-bold text-white","children":"No physical cues"}],["$","p",null,{"className":"mt-2 text-sm text-zinc-400 leading-relaxed","children":"In an office, people walking to a conference room remind you it's time. Working from home, there are no external cues."}]]}],["$","div","Context switching",{"className":"rounded-2xl border border-zinc-800 bg-zinc-900 p-6","children":[["$","h3",null,{"className":"font-bold text-white","children":"Context switching"}],["$","p",null,{"className":"mt-2 text-sm text-zinc-400 leading-relaxed","children":"Jumping between tasks, Slack, email, and actual work makes it easy to lose track of time entirely."}]]}],["$","div","Notification overload",{"className":"rounded-2xl border border-zinc-800 bg-zinc-900 p-6","children":["$L14","$L15"]}],"$L16"]}]]}]}],"$L17","$L18","$L19","$L1a","$L1b"],null,"$L1c"]}]
