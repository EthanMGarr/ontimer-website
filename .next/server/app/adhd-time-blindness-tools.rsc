10:["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"WebPage\",\"name\":\"Tools That Help With ADHD Time Blindness\",\"description\":\"A guide to tools and strategies for managing ADHD time blindness, including calendar alarm apps.\",\"url\":\"https://www.ontimer.app/adhd-time-blindness-tools\"}"}}],["$","section",null,{"className":"relative overflow-hidden pb-20 pt-24 md:pt-32","children":[["$","div",null,{"className":"pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,rgba(34,197,94,0.15),transparent)]"}],["$","div",null,{"className":"mx-auto max-w-3xl px-4 sm:px-6","children":[["$","h1",null,{"className":"text-5xl font-black tracking-tight text-white sm:text-6xl","children":["Tools That Help With"," ",["$","span",null,{"className":"text-green-500","children":"ADHD Time Blindness"}]]}],["$","p",null,{"className":"mt-6 text-lg text-zinc-400 leading-relaxed","children":"Time blindness — difficulty perceiving the passage of time — is one of the most common challenges for people with ADHD. It makes it easy to lose track of meetings, deadlines, and appointments, even when reminders are set."}],["$","p",null,{"className":"mt-4 text-lg text-zinc-400 leading-relaxed","children":"This guide covers practical tools and strategies that work, and why alarm-based calendar apps are especially effective."}],["$","div",null,{"className":"mt-8 flex flex-wrap items-center gap-4","children":[["$","$L7",null,{"size":"lg"}],["$","$L13",null,{"size":"lg"}]]}]]}]]}],["$","section",null,{"className":"border-t border-zinc-800 bg-zinc-900/50 py-20","children":["$","div",null,{"className":"mx-auto max-w-3xl px-4 sm:px-6","children":[["$","h2",null,{"className":"text-3xl font-black tracking-tight text-white sm:text-4xl","children":"What Time Blindness Is"}],["$","div",null,{"className":"mt-6 space-y-4 text-zinc-400 leading-relaxed","children":[["$","p",null,{"children":"Time blindness is a term used to describe the difficulty some people — particularly those with ADHD — have in accurately perceiving how much time has passed or is remaining."}],["$","p",null,{"children":"It's not about forgetting that a meeting exists. It's about genuinely losing track of how quickly time is moving."}],["$","p",null,{"children":"Someone with time blindness might sit down to finish a five-minute task before a meeting, then look up and realize thirty minutes have passed. The meeting already started."}],["$","p",null,{"children":"This isn't a motivation problem. It's a neurological one — and it requires tools that don't rely solely on self- awareness."}]]}]]}]}],["$","section",null,{"className":"py-20","children":["$","div",null,{"className":"mx-auto max-w-3xl px-4 sm:px-6","children":[["$","h2",null,{"className":"text-3xl font-black tracking-tight text-white sm:text-4xl","children":"Why People With ADHD Miss Meetings"}],["$","p",null,{"className":"mt-4 text-zinc-400","children":"Missing meetings despite using calendar reminders is common with ADHD for several reasons:"}],["$","ul",null,{"className":"mt-6 space-y-3","children":[["$","li","ADHD makes it harder to notice the passage of time",{"className":"flex items-start gap-3 text-zinc-400","children":[["$","span",null,{"className":"mt-1 flex-shrink-0 text-green-500","children":"•"}],"ADHD makes it harder to notice the passage of time"]}],["$","li","notifications disappear too quickly to register",{"className":"flex items-start gap-3 text-zinc-400","children":[["$","span",null,{"className":"mt-1 flex-shrink-0 text-green-500","children":"•"}],"notifications disappear too quickly to register"]}],["$","li","hyperfocus can block out even loud alerts",{"className":"flex items-start gap-3 text-zinc-400","children":[["$","span",null,{"className":"mt-1 flex-shrink-0 text-green-500","children":"•"}],"hyperfocus can block out even loud alerts"]}],"$L14","$L15"]}],"$L16"]}]}],"$L17","$L18","$L19","$L1a","$L1b","$L1c"],null,"$L1d"]}]
