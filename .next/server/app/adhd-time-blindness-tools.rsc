16:["$","p",null,{"className":"mt-6 text-zinc-400 leading-relaxed","children":"Standard calendar reminders were designed for people who need a gentle nudge. For people with time blindness, a gentle nudge often isn't enough."}]
17:["$","section",null,{"className":"border-t border-zinc-800 bg-zinc-900/50 py-20","children":["$","div",null,{"className":"mx-auto max-w-3xl px-4 sm:px-6","children":[["$","h2",null,{"className":"text-3xl font-black tracking-tight text-white sm:text-4xl","children":"Why Standard Calendar Reminders Often Fail"}],["$","div",null,{"className":"mt-6 space-y-4 text-zinc-400 leading-relaxed","children":[["$","p",null,{"children":"Google Calendar and Outlook send notification banners that appear briefly on your screen and then disappear."}],["$","p",null,{"children":"For someone in a state of hyperfocus — common with ADHD — a brief notification on the edge of the screen may not break through at all."}],["$","p",null,{"children":"And even if you do see it, a notification doesn't require action. You can glance at it and go right back to what you were doing, with the intention of joining in a minute — which never comes."}]]}]]}]}]
18:["$","section",null,{"className":"py-20","children":["$","div",null,{"className":"mx-auto max-w-3xl px-4 sm:px-6","children":[["$","h2",null,{"className":"text-3xl font-black tracking-tight text-white sm:text-4xl","children":"Tools That Help Manage Time Blindness"}],["$","p",null,{"className":"mt-4 text-zinc-400","children":"The most effective tools for time blindness share one trait: they make time visible or impossible to ignore."}],["$","div",null,{"className":"mt-6 grid gap-4 sm:grid-cols-2","children":[["$","div","Visual timers",{"className":"rounded-2xl border border-zinc-800 bg-zinc-900 p-6","children":[["$","h3",null,{"className":"font-bold text-white","children":"Visual timers"}],["$","p",null,{"className":"mt-2 text-sm text-zinc-400 leading-relaxed","children":"Physical or digital timers that show time passing visually. Help make the passage of time concrete."}]]}],["$","div","Time blocking",{"className":"rounded-2xl border border-zinc-800 bg-zinc-900 p-6","children":[["$","h3",null,{"className":"font-bold text-white","children":"Time blocking"}],["$","p",null,{"className":"mt-2 text-sm text-zinc-400 leading-relaxed","children":"Structuring your day into explicit time blocks on your calendar so you always know what should be happening."}]]}],["$","div","Alarm-based calendar apps",{"className":"rounded-2xl border border-zinc-800 bg-zinc-900 p-6","children":[["$","h3",null,{"className":"font-bold text-white","children":"Alarm-based calendar apps"}],["$","p",null,{"className":"mt-2 text-sm text-zinc-400 leading-relaxed","children":"Apps that turn calendar events into persistent alarms — not just notifications — so meetings can't be ignored."}]]}],["$","div","External cues",{"className":"rounded-2xl border border-zinc-800 bg-zinc-900 p-6","children":[["$","h3",null,{"className":"font-bold text-white","children":"External cues"}],["$","p",null,{"className":"mt-2 text-sm text-zinc-400 leading-relaxed","children":"Sounds, vibrations, or visual alerts that interrupt you and bring your attention back to time-sensitive tasks."}]]}]]}]]}]}]
19:["$","section",null,{"className":"border-t border-zinc-800 bg-zinc-900/50 py-20","children":["$","div",null,{"className":"mx-auto max-w-3xl px-4 sm:px-6","children":[["$","h2",null,{"className":"text-3xl font-black tracking-tight text-white sm:text-4xl","children":"Why Alarm-Based Systems Work Better"}],["$","div",null,{"className":"mt-6 space-y-4 text-zinc-400 leading-relaxed","children":[["$","p",null,{"children":"The key difference between a notification and an alarm is that an alarm requires a response. It doesn't wait for you to notice it — it demands your attention."}],["$","p",null,{"children":"For people with ADHD, external interruption is often necessary to break out of hyperfocus or a time blindness episode. A persistent alarm provides that interruption in a way that a passive notification cannot."}],["$","p",null,{"children":["A"," ",["$","strong",null,{"className":"text-white","children":"calendar alarm app"}]," applies this same logic to your meeting schedule — converting passive reminders into persistent alarms tied to your actual calendar events."]}]]}]]}]}]
