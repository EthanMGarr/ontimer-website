f:["$","$1","c",{"children":[["$","section",null,{"className":"py-20","children":["$","div",null,{"className":"mx-auto max-w-3xl px-4 sm:px-6","children":[["$","h1",null,{"className":"text-4xl font-black tracking-tight text-white sm:text-5xl","children":"Privacy Policy"}],["$","p",null,{"className":"mt-3 text-sm text-zinc-500","children":"Last updated: January 1, 2025"}],["$","div",null,{"className":"prose mt-10","children":[["$","h2",null,{"children":"Our Commitment to Privacy"}],["$","p",null,{"children":"OnTimer is built on a simple principle: your data is yours. We designed the app to work entirely on your device, without any servers, accounts, or cloud infrastructure on our end."}],["$","h2",null,{"children":"What We Collect"}],["$","p",null,{"children":[["$","strong",null,{"children":"We collect nothing."}]," OnTimer does not collect, store, transmit, or share any personal information, calendar data, or usage data. The app operates entirely on-device."]}],["$","h2",null,{"children":"Calendar Access"}],["$","p",null,{"children":"OnTimer requests read-only access to your iPhone calendar via the standard iOS Calendar permission. This access is used solely to read event times and titles to set your alarms. We do not upload, sync, or store your calendar data anywhere outside your device. OnTimer cannot modify your calendar."}],["$","h2",null,{"children":"Notifications"}],["$","p",null,{"children":"OnTimer requests permission to send you local notifications (alarms). These notifications are generated on your device and do not involve any network communication. They contain only information from your own calendar that OnTimer read locally."}],["$","h2",null,{"children":"Analytics and Tracking"}],["$","p",null,{"children":"OnTimer contains no analytics SDKs, tracking pixels, or any third-party code that monitors your behavior. We do not use Apple's App Analytics beyond what Apple provides to all developers in App Store Connect (aggregate, anonymized stats that Apple collects, not us)."}],["$","h2",null,{"children":"Third-Party Services"}],["$","p",null,{"children":"OnTimer does not integrate with any third-party services, APIs, or data processors. There are no social login providers, payment processors, or advertising networks in the app."}],["$","h2",null,{"children":"Children's Privacy"}],["$","p",null,{"children":"OnTimer does not knowingly collect any information from children under 13. Because we collect no information from anyone, this is a naturally satisfied condition."}],["$","h2",null,{"children":"Changes to This Policy"}],["$","p",null,{"children":"If we ever change our privacy practices, we will update this page with a new effective date. Significant changes will be noted in the app update release notes."}],["$","h2",null,{"children":"Contact"}],["$","p",null,{"children":["If you have any questions about this privacy policy, please contact us at"," ",["$","a",null,{"href":"mailto:privacy@ontimer.app","children":"privacy@ontimer.app"}],"."]}]]}]]}]}],null,["$","$L12",null,{"children":["$L13",["$","$L14",null,{"promise":"$@15"}]]}]]}]
