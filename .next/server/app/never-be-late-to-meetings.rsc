13:["$","p",null,{"className":"mt-1","children":"Instead of \"my meeting is at 2:00 PM,\" think \"I need to leave at 1:30 PM.\" Set your alarm for 1:30. That's the only time that matters."}]
14:["$","section",null,{"className":"mb-14","children":[["$","h2",null,{"className":"mb-4 text-2xl font-black tracking-tight text-white sm:text-3xl","children":"How OnTimer Solves This"}],["$","p",null,{"className":"mb-6 text-zinc-400 leading-relaxed","children":"Setting manual departure alarms for every meeting is better than relying on reminders — but it's still overhead. You have to remember to set them, update them when meetings change, and delete them when events get cancelled. OnTimer removes all of that."}],["$","ul",null,{"className":"space-y-4","children":[["$","li","Connects to your calendar",{"className":"flex gap-4 rounded-xl border border-zinc-800 bg-zinc-900 p-5","children":[["$","span",null,{"className":"flex-shrink-0 text-2xl","children":"📅"}],["$","div",null,{"children":[["$","p",null,{"className":"font-bold text-white","children":"Connects to your calendar"}],["$","p",null,{"className":"mt-1 text-sm text-zinc-400","children":"OnTimer reads your iPhone calendar — including Google Calendar, iCloud, Outlook, and others — and sees all your upcoming events automatically. You don't enter anything manually."}]]}]]}],["$","li","Automatically creates alarms before events",{"className":"flex gap-4 rounded-xl border border-zinc-800 bg-zinc-900 p-5","children":[["$","span",null,{"className":"flex-shrink-0 text-2xl","children":"⏰"}],["$","div",null,{"children":[["$","p",null,{"className":"font-bold text-white","children":"Automatically creates alarms before events"}],["$","p",null,{"className":"mt-1 text-sm text-zinc-400","children":"For every event with a time, OnTimer creates an alarm based on your chosen lead time. A 30-minute lead time means your alarm fires 30 minutes before you need to be there — giving you time to actually leave."}]]}]]}],["$","li","No manual setup, ever",{"className":"flex gap-4 rounded-xl border border-zinc-800 bg-zinc-900 p-5","children":[["$","span",null,{"className":"flex-shrink-0 text-2xl","children":"🔄"}],["$","div",null,{"children":[["$","p",null,{"className":"font-bold text-white","children":"No manual setup, ever"}],["$","p",null,{"className":"mt-1 text-sm text-zinc-400","children":"When a meeting gets rescheduled, your alarm updates. When it's cancelled, the alarm disappears. You don't have to touch anything."}]]}]]}],["$","li","Persistent, can't-miss alerts",{"className":"flex gap-4 rounded-xl border border-zinc-800 bg-zinc-900 p-5","children":[["$","span",null,{"className":"flex-shrink-0 text-2xl","children":"🔔"}],["$","div",null,{"children":[["$","p",null,{"className":"font-bold text-white","children":"Persistent, can't-miss alerts"}],["$","p",null,{"className":"mt-1 text-sm text-zinc-400","children":"OnTimer uses real alarms — not silent notifications. They escalate until you acknowledge them, so you can't sleep through or miss them the way you might a calendar banner."}]]}]]}]]}],["$","div",null,{"className":"mt-6 flex flex-wrap gap-3","children":[["$","$L6",null,{"href":"/features","className":"text-sm font-semibold text-green-500 hover:text-green-400","children":"See all features →"}],["$","span",null,{"className":"text-zinc-600","children":"·"}],["$","$L6",null,{"href":"/how-it-works","className":"text-sm font-semibold text-green-500 hover:text-green-400","children":"How it works, step by step →"}]]}]]}]
15:["$","section",null,{"className":"mb-14","children":[["$","h2",null,{"className":"mb-4 text-2xl font-black tracking-tight text-white sm:text-3xl","children":"Who This Helps Most"}],["$","p",null,{"className":"mb-6 text-zinc-400 leading-relaxed","children":"Chronic lateness affects people for different reasons. OnTimer works for all of them, because the fix is the same: an automatic alarm that fires at the right moment."}],["$","div",null,{"className":"grid gap-4 sm:grid-cols-2","children":[["$","div","Back-to-back meeting days",{"className":"rounded-xl border border-zinc-800 bg-zinc-900 p-5","children":[["$","p",null,{"className":"mb-1.5 font-bold text-white","children":"Back-to-back meeting days"}],["$","p",null,{"className":"text-sm text-zinc-400","children":"When you're going from one call to the next, it's easy to lose track of time. OnTimer alarms for each transition so you can focus on the current meeting without watching the clock."}]]}],["$","div","ADHD and time blindness",{"className":"rounded-xl border border-zinc-800 bg-zinc-900 p-5","children":[["$","p",null,{"className":"mb-1.5 font-bold text-white","children":"ADHD and time blindness"}],["$","p",null,{"className":"text-sm text-zinc-400","children":"Time blindness — the difficulty sensing how much time has passed — is common with ADHD. OnTimer's loud, persistent alarms cut through hyperfocus and signal when it's genuinely time to stop."}]]}],["$","div","Busy professionals",{"className":"rounded-xl border border-zinc-800 bg-zinc-900 p-5","children":[["$","p",null,{"className":"mb-1.5 font-bold text-white","children":"Busy professionals"}],["$","p",null,{"className":"text-sm text-zinc-400","children":"When you're deep in work, a meeting can sneak up fast. OnTimer removes the need to manually track your schedule by making your calendar do the work for you."}]]}],["$","div","Remote workers",{"className":"rounded-xl border border-zinc-800 bg-zinc-900 p-5","children":[["$","p",null,{"className":"mb-1.5 font-bold text-white","children":"Remote workers"}],["$","p",null,{"className":"text-sm text-zinc-400","children":"Without a commute to force routine, remote workers often shift meetings later and later. OnTimer keeps you honest about when virtual meetings start — no more rushing to find the Zoom link at 10:03."}]]}]]}]]}]
