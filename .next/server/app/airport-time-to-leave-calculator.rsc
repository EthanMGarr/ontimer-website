27:["$","details","How much extra time should I allow for parking?",{"className":"group py-5","children":[["$","summary",null,{"className":"flex cursor-pointer list-none items-center justify-between gap-4 text-white","children":[["$","span",null,{"className":"font-semibold leading-snug","children":"How much extra time should I allow for parking?"}],["$","span",null,{"className":"flex-shrink-0 text-lg text-green-500 transition-transform duration-200 group-open:rotate-45","children":"+"}]]}],["$","p",null,{"className":"mt-4 text-sm leading-relaxed text-zinc-400","children":"Add at least 15–20 minutes for airport parking. This accounts for finding a spot, waiting for a shuttle, and the ride to the terminal. Economy lots are farther away and can easily add 30 minutes round-trip."}]]}]
28:["$","details","Should I arrive earlier if I'm checking a bag?",{"className":"group py-5","children":[["$","summary",null,{"className":"flex cursor-pointer list-none items-center justify-between gap-4 text-white","children":[["$","span",null,{"className":"font-semibold leading-snug","children":"Should I arrive earlier if I'm checking a bag?"}],["$","span",null,{"className":"flex-shrink-0 text-lg text-green-500 transition-transform duration-200 group-open:rotate-45","children":"+"}]]}],["$","p",null,{"className":"mt-4 text-sm leading-relaxed text-zinc-400","children":"Yes. Most airlines close bag check 30–45 minutes before departure. If you're running late and can't check your bag, you may be denied boarding. Add 15–20 minutes to your buffer if you're checking luggage."}]]}]
29:["$","details","Can OnTimer remind me when to leave for the airport?",{"className":"group py-5","children":[["$","summary",null,{"className":"flex cursor-pointer list-none items-center justify-between gap-4 text-white","children":[["$","span",null,{"className":"font-semibold leading-snug","children":"Can OnTimer remind me when to leave for the airport?"}],["$","span",null,{"className":"flex-shrink-0 text-lg text-green-500 transition-transform duration-200 group-open:rotate-45","children":"+"}]]}],["$","p",null,{"className":"mt-4 text-sm leading-relaxed text-zinc-400","children":"OnTimer is built for calendar events with locations — like flights, meetings, and appointments. For any event with an address, OnTimer's Time-to-Leave feature can alert you when it's time to head out, based on travel time and traffic. Time-to-Leave is a Pro feature."}]]}]
