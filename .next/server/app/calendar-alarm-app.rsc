10:["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"WebPage\",\"name\":\"What Is a Calendar Alarm App?\",\"description\":\"A calendar alarm app turns calendar events into persistent alarms so you never miss meetings. Learn how it differs from standard reminders.\",\"url\":\"https://www.ontimer.app/calendar-alarm-app\"}"}}],["$","section",null,{"className":"relative overflow-hidden pb-20 pt-24 md:pt-32","children":[["$","div",null,{"className":"pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,rgba(34,197,94,0.15),transparent)]"}],["$","div",null,{"className":"mx-auto max-w-3xl px-4 sm:px-6","children":[["$","h1",null,{"className":"text-5xl font-black tracking-tight text-white sm:text-6xl","children":["What Is a"," ",["$","span",null,{"className":"text-green-500","children":"Calendar Alarm App?"}]]}],["$","p",null,{"className":"mt-6 text-lg text-zinc-400 leading-relaxed","children":"A calendar alarm app turns your calendar events into persistent alarms — not passive notifications. Instead of a banner that disappears, you get an alert that stays on your screen until you dismiss it."}],["$","p",null,{"className":"mt-4 text-lg text-zinc-400 leading-relaxed","children":"For professionals who rely on their calendar to manage their day, this distinction matters."}],["$","div",null,{"className":"mt-8 flex flex-wrap items-center gap-4","children":[["$","$L7",null,{"size":"lg"}],["$","$L13",null,{"size":"lg"}]]}]]}]]}],["$","section",null,{"className":"border-t border-zinc-800 bg-zinc-900/50 py-20","children":["$","div",null,{"className":"mx-auto max-w-3xl px-4 sm:px-6","children":[["$","h2",null,{"className":"text-3xl font-black tracking-tight text-white sm:text-4xl","children":"Why Calendar Notifications Aren't Enough"}],["$","p",null,{"className":"mt-4 text-zinc-400","children":"Standard calendar reminders — from Google Calendar, Outlook, or built-in phone calendars — are delivered as notifications. And notifications have a fundamental limitation:"}],["$","div",null,{"className":"mt-6 space-y-4","children":[["$","div","They disappear automatically",{"className":"rounded-xl border border-zinc-800 bg-zinc-900 px-5 py-4","children":[["$","p",null,{"className":"font-semibold text-white","children":"They disappear automatically"}],["$","p",null,{"className":"mt-1 text-sm text-zinc-400","children":"A notification banner vanishes after a few seconds whether you act on it or not."}]]}],["$","div","They can be dismissed by accident",{"className":"rounded-xl border border-zinc-800 bg-zinc-900 px-5 py-4","children":[["$","p",null,{"className":"font-semibold text-white","children":"They can be dismissed by accident"}],["$","p",null,{"className":"mt-1 text-sm text-zinc-400","children":"A quick swipe and the reminder is gone — even if you didn't consciously decide to ignore it."}]]}],["$","div","They compete with everything else",{"className":"rounded-xl border border-zinc-800 bg-zinc-900 px-5 py-4","children":[["$","p",null,{"className":"font-semibold text-white","children":"They compete with everything else"}],["$","p",null,{"className":"mt-1 text-sm text-zinc-400","children":"Your phone shows dozens of notifications per day. Calendar reminders don't stand out."}]]}],["$","div","They don't interrupt deep work",{"className":"rounded-xl border border-zinc-800 bg-zinc-900 px-5 py-4","children":[["$","p",null,{"className":"font-semibold text-white","children":"They don't interrupt deep work"}],["$","p",null,{"className":"mt-1 text-sm text-zinc-400","children":"When you're focused, notifications fade into the background — especially with focus mode on."}]]}]]}]]}]}],["$","section",null,{"className":"py-20","children":["$","div",null,{"className":"mx-auto max-w-3xl px-4 sm:px-6","children":[["$","h2",null,{"className":"text-3xl font-black tracking-tight text-white sm:text-4xl","children":"The Difference B